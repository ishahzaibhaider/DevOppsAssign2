<%- include('partials/header') %>

<section class="card form-card">
  <h2>Add New Student</h2>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/add" method="POST">
    <div class="form-group">
      <label for="name">Full Name</label>
      <input type="text" id="name" name="name" placeholder="e.g. Ali Hassan" required />
    </div>

    <div class="form-group">
      <label for="rollNumber">Roll Number</label>
      <input type="text" id="rollNumber" name="rollNumber" placeholder="e.g. SP21-BCS-001" required />
    </div>

    <div class="form-group">
      <label for="course">Course</label>
      <input type="text" id="course" name="course" placeholder="e.g. DevOps for Cloud Computing" required />
    </div>

    <div class="form-group">
      <label for="marks">Marks (0–100)</label>
      <input type="number" id="marks" name="marks" min="0" max="100" placeholder="e.g. 85" required />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Student</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</section>

  </main>
  <footer>DevOps Assignment 2 &mdash; COMSATS University Islamabad</footer>
</body>
</html>
